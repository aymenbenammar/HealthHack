APP_NAME=HealthHack API
APP_VERSION=0.1.0
DEBUG=false

API_V1_PREFIX=/api/v1

DATABASE_URL=sqlite:///./healthhack.db

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# LLM provider: "groq" (default) or "anthropic" (Claude Opus 4.7)
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_DEFAULT_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_DEFAULT_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Anthropic (Claude) — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7
